# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=typing_trainer
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/typing_trainer

# JWT - IMPORTANT: Change in production!
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars-very-important
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Add your production domain here
# В production через nginx proxy CORS обрабатывается автоматически
# Но нужно указать origin для прямых запросов (если будут)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80,http://localhost,https://yourdomain.com

# App
DEBUG=false
API_PORT=8000
FRONTEND_PORT=80

